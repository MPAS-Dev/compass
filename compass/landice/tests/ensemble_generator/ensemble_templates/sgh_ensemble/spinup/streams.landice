<streams>

<immutable_stream name="basicmesh"
                  filename_template="not-to-be-used.nc"
                  type="none"/>

<immutable_stream name="input"
                  filename_template="{{ input_file_init_cond }}"
                  input_interval="initial_only"
                  type="input"/>

<immutable_stream name="restart"
                  filename_interval="output_interval"
                  clobber_mode="overwrite"
                  precision="double"
                  output_interval="0005-00-00_00:00:00"
                  filename_template="rst.$Y-$M-$D.nc"
                  input_interval="initial_only"
                  type="input;output"
                  input_interal="initial_only"/>

<stream name="output"
        type="output"
        filename_template="output/output_$Y.nc"
        filename_interval="0020-00-00_00:00:00"
        reference_time="2000-01-01_00:00:00"
        clobber_mode="overwrite"
        precision="double"
        output_interval="0001-00-00_00:00:00">

    <stream name="basicmesh"/>
    <var name="xtime"/>
    <var name="simulationStartTime"/>
    <var name="thickness"/>
    <var name="bedTopography"/>
    <var name="daysSinceStart"/>
    <var name="cellProcID"/>
    <var name="cellMask"/>
    <var name="waterThickness"/>
    <var name="effectivePressure"/>
	 <var name="waterPressure"/>
	 <var name="waterFlux"/>
	 <var name="channelDischarge"/>
	 <var name="channelArea"/>
	 <var name="diffusivity"/>
	 <var name="channelVelocity"/>
	 <var name="channelClosingRate"/>
	 <var name="channelOpeningRate"/>
	 <var name="divergence"/>
	 <var name="hydropotential"/>
	 <var name="basalMeltInput"/>
	 <var name="basalHeatFlux"/>
	 <var name="basalFrictionFlux"/>
	 <var name="basalSpeed"/>
</stream>

<stream name="globalStatsOutput"
        type="output"
        filename_template="output/globalStats.nc"
        filename_interval="none"
        reference_time="2015-01-01_00:00:00"
        clobber_mode="overwrite"
        packages="globalStatsAMPKG"
        output_interval="0000-01-00_00:00:00"
        runtime_format="single_file">

    <var_struct name="globalStatsAM"/>
    <var name="xtime"/>
    <var name="simulationStartTime"/>
    <var name="daysSinceStart"/>
    <var name="deltat"/>
    <var name="allowableDtACFL"/>
    <var name="allowableDtDCFL"/>
    <var name="albanyVelocityError"/>
    <var name="totalSubglacialWaterVolume"/>
    <var name="totalBasalMeltInput"/>
    <var name="totalDistWaterFluxMarineMargin"/>
    <var name="totalDistWaterFluxTerrestrialMargin"/>
    <var name="avgFlotationFraction"/>
</stream>

</streams>
